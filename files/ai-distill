# ── Sanitization tunables (§7 req 3) ──────────────────────────────────────
MAX_FILE_BYTES = 512 * 1024        # 3.d size bound for a derived memory file
MIN_RUN = 12                       # 3.b decode threshold (candidate chars);
                                   # low, to catch short scattered fragments
TEXT_RATIO = 0.85                  # printable ratio to call decoded bytes text
LARGE_BINARY = 512                 # decoded binary beyond this → item invalid
DECODE_DEPTH = 4                   # 3.b recursion depth cap (termination guard)

# Invisible characters stripped in 3.a. Zero-width joiner (U+200D) is kept —
# legitimate emoji sequences need it. BOM/word-joiner/bidi overrides go.
INVISIBLE = dict.fromkeys([
    0x200B, 0x200C,                        # zero-width space / non-joiner
    0x2060, 0xFEFF,                        # word-joiner / BOM (zero-width nbsp)
    0x202A, 0x202B, 0x202C, 0x202D, 0x202E,  # bidi embeddings/overrides
    0x2066, 0x2067, 0x2068, 0x2069,          # bidi isolates (Trojan Source)
], None)

# One candidate-run regex. Hex is a subset of the base64 alphabet, so a hex
# run of length ≥ MIN_RUN is matched here too; try_decode_run tries hex first,
# so a separate hex regex would only double-count the same span.
B64_RUN = re.compile(r"[A-Za-z0-9+/]{%d,}={0,2}" % MIN_RUN)

# Files a hub (workspace ai/) promotion may touch — prose sources only.
# mcp.json/commands/skills/agents are executable/structured config the pipeline
# never proposes (§7 req 9); prose can't validly live there.
HUB_FILE = re.compile(r"^ai/(AGENTS\.md|rules/[\w./-]+\.md)$")
# Files a change must NOT touch in any target repo — executable/structured
# config, never distilled prose.
EXEC_CONFIG = re.compile(r"(?:\.json|\.ya?ml|\.toml|\.sh|\.py|\.js|\.ts)$"
                         r"|(?:^|/)(?:hooks|scripts)/")
# Executable/structured config appearing as *content* in an otherwise-prose
# file (e.g. an mcpServers or command/args block pasted into AGENTS.md).
EXEC_CONTENT = re.compile(r'"mcpServers"\s*:'
                          r'|"command"\s*:\s*"[^"]*"[\s\S]{0,200}?"args"\s*:')

# Natural-language words that a prose instruction carries but a shell command
# line does not — the discriminator in looks_executable().
FUNCTION_WORDS = frozenset("""a an the this that these those and or but nor for
    to of in on at by from with as into onto over under per via not never
    always prefer use avoid ensure when where if unless while do don't is are
    be only also than then it its their your our no all any each every""".split())

# Conservative secret patterns for the builtin fallback (real gitleaks is
# preferred when on PATH; see req 11).
SECRET_PATTERNS = [
    ("github-pat", re.compile(r"\b(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]{20,}")),
    ("github-fine-pat", re.compile(r"\bgithub_pat_[A-Za-z0-9_]{20,}")),
    ("aws-akid", re.compile(r"\bAKIA[0-9A-Z]{16}\b")),
    ("private-key", re.compile(r"-----BEGIN (?:RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----")),
    ("slack-token", re.compile(r"\bxox[baprs]-[A-Za-z0-9-]{10,}")),
    ("generic-assign", re.compile(
        r"(?i)(secret|token|passwd|password|api[_-]?key)\s*[:=]\s*['\"][^'\"]{8,}['\"]")),
]


def now():
    return datetime.now(timezone.utc)


def iso(ts):
    return datetime.fromtimestamp(ts, timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def load_json(path):
    try:
        with open(path, encoding="utf-8") as fh:
            text = fh.read()
        return json.loads(text) if text.strip() else {}
    except FileNotFoundError:
        return None
    except (ValueError, OSError) as exc:
        sys.stderr.write("✗ error: cannot read %s: %s\n" % (path, exc))
        return None


def write_json(path, obj):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as fh:
        json.dump(obj, fh, indent=2, ensure_ascii=False)
        fh.write("\n")
    os.replace(tmp, path)
    os.chmod(path, 0o600)


def sha256_bytes(data):
    return hashlib.sha256(data).hexdigest()


def file_path_of(url):
    parsed = urlparse(url)
    if parsed.scheme != "file":
        return None
    return unquote(parsed.path)


# ── 3.a–3.d sanitization ──────────────────────────────────────────────────

def decode_text(data):
    """3.a intrinsic decode: accept only encodings a deterministic check
    identifies. Returns (text, encoding) or (None, None) for binary."""
    if data.startswith(b"\xef\xbb\xbf"):
        try:
            return data[3:].decode("utf-8"), "utf-8-bom"
        except UnicodeDecodeError:
            return None, None
    if data.startswith((b"\xff\xfe\x00\x00", b"\x00\x00\xfe\xff")):
        try:
            return data.decode("utf-32"), "utf-32-bom"
        except (UnicodeDecodeError, LookupError):
            return None, None
    if data.startswith((b"\xff\xfe", b"\xfe\xff")):
        try:
            return data.decode("utf-16"), "utf-16-bom"
        except UnicodeDecodeError:
            return None, None
    try:
        return data.decode("utf-8"), "utf-8"
    except UnicodeDecodeError:
        return None, None


LOOKALIKE_TAGS = ("<wide>", "<narrow>", "<font>", "<circle>")


def has_letter_lookalike(text):
    """A compatibility character that *impersonates* an ASCII letter/digit — a
    width, narrow, font, or circled variant that NFKC-folds to a single ASCII
    alphanumeric (fullwidth `ｉｇｎｏｒｅ` → `ignore`). Ordinary typography that
    also folds to ASCII (… — ½ ™ ² ℃ ﬁ) decomposes under other tags
    (fraction/super/square/compat) and is deliberately ignored, so this fires
    only on genuine impersonation, not on punctuation or symbols."""
    for ch in text:
        if ch.isascii():
            continue
        if not unicodedata.decomposition(ch).startswith(LOOKALIKE_TAGS):
            continue
        folded = unicodedata.normalize("NFKC", ch)
        if len(folded) == 1 and folded.isascii() and folded.isalnum():
            return True
    return False


def canonicalize(text):
    """3.a: NFC, strip invisibles/bidi (keep ZWJ), normalize line endings.
    Returns (canonical_text, letter_lookalike)."""
    text = unicodedata.normalize("NFC", text)
    text = text.translate(INVISIBLE)
    text = text.replace("\r\n", "\n").replace("\r", "\n")
    return text, has_letter_lookalike(text)


def looks_textual(data):
    try:
        s = data.decode("utf-8")
    except UnicodeDecodeError:
        return None
    if not s:
        return None
    printable = sum(ch.isprintable() or ch in "\n\t " for ch in s)
    return s if printable / len(s) >= TEXT_RATIO else None


def try_decode_run(run):
    """Return decoded bytes for an encoded run, or None if it is not a
    decodable encoding."""
    candidate = run.rstrip("=")
    if re.fullmatch(r"[0-9a-fA-F]+", run) and len(run) % 2 == 0:
        try:
            return bytes.fromhex(run)
        except ValueError:
            pass
    if len(candidate) % 4 != 1:  # a base64 body is never length%4==1
        try:
            return base64.b64decode(run + "=" * (-len(run) % 4), validate=True)
        except (binascii.Error, ValueError):
            pass
    return None


def unwrap(text, depth, annotations):
    """3.b opacity unwrapping. Reveals encoded text as annotations (never
    spliced into `text`), counts unwrappings, flags a large decoded binary.
    Returns (score, invalid_reason_or_None)."""
    if depth > DECODE_DEPTH:
        # Termination-guard limit hit — surfaced to triage (§7 req 3.c/8.a),
        # not swallowed silently.
        annotations.append({"kind": "depth-limit-hit", "depth": depth})
        return 0, None
    score = 0
    for match in B64_RUN.finditer(text):
        run = match.group(0)
        data = try_decode_run(run)
        if data is None:
            continue
        revealed = looks_textual(data)
        if revealed is not None:
            score += 1
            canon, _ = canonicalize(revealed)
            annotations.append({"kind": "revealed-text", "depth": depth,
                                "from": run[:24] + ("…" if len(run) > 24 else ""),
                                "text": canon})
            sub, invalid = unwrap(canon, depth + 1, annotations)
            score += sub
            if invalid:
                return score, invalid
        elif len(data) > LARGE_BINARY:
            score += 1
            return score, ("encoded large binary (%d bytes) in text" % len(data))
        # else: small opaque token (hash/id) — left as-is, not counted.
    return score, None


def frontmatter_ok(text):
    """3.d: if the file opens with YAML frontmatter it must close and be
    non-empty and key-shaped. Files without frontmatter (e.g. index files)
    are fine."""
    if not text.startswith("---\n"):
        return True
    end = text.find("\n---", 4)
    if end == -1:
        return False
    block = text[4:end].strip()
    if not block:
        return False
    return any(re.match(r"^\s*[\w.-]+\s*:", line) for line in block.splitlines())


def sanitize(data):
    """Full 3.a–3.d on raw bytes. Returns a dict with either canonical text +
    annotations + score, or an `invalid` reason."""
    if len(data) > MAX_FILE_BYTES:
        return {"invalid": "oversize (%d bytes > %d)" % (len(data), MAX_FILE_BYTES)}
    text, encoding = decode_text(data)
    if text is None:
        return {"invalid": "not decodable as an accepted text encoding (binary)"}
    canon, nfkc_differs = canonicalize(text)
    annotations = []
    if nfkc_differs:
        annotations.append({"kind": "nfkc-lookalike",
                            "note": "compatibility characters present (fullwidth/lookalike)"})
    score, invalid = unwrap(canon, 1, annotations)
    if invalid:
        return {"invalid": invalid}
    if not frontmatter_ok(canon):
        return {"invalid": "malformed frontmatter"}
    return {"text": canon, "encoding": encoding, "annotations": annotations,
            "opacity_score": score}


# ── Identifier denylist (§7 req 5.a; deterministic, from machine state) ────

# Generic-word screen. The denylist is built by splitting the operator's own
# slugs, repo names, and git remotes into tokens; a token that is an ordinary
# known word is not an identifier and must not be redacted, or general prose
# ("release", "identity", "ssh", "http") would be wrongly rejected. Two curated
# word sets are released from redaction, replacing a hand-maintained stop-list
# that could never cover the space:
#   1. SCOWL English words (basis of GNU Aspell and the Unix `words` packages;
#      see ai-wordlist.NOTICE) — a vendored .gz, pinned by sha256 and integrity-
#      checked. Only lowercase-canonical entries are vendored, which drops
#      SCOWL's capitalized proper nouns (personal, place, company names); the
#      .gz is built `gzip -n` so the pin is reproducible from the plaintext.
#   2. Technical known-terms (ai-terms.txt) — software/DevOps terms and acronyms
#      (ssh, sdk, ansible, docker, ldap, json…) from cspell's curated
#      `software-terms` dictionary (MIT). A small vendored, git-reviewed
#      plaintext file. Dedicated proper-noun dictionaries (people/place/company
#      names) and package registries are excluded, as their coined names share
#      the identifier namespace.
# Residual (accepted, §7 req 5.c — recurrence + human review): a few dual-use
# tokens are both a common word and a name (a surname that is also a noun; a
# vendor name that appears in the tech vocabulary) and are released. The
# operator's OWN identity is exempt from the screen: build_denylist redacts the
# git-config name/handle unconditionally, since a name that is also a word is
# still the operator's name. No identity is hardcoded (invariant 5).
WORDLIST_SHA256 = "1a57abaa8a195687332d39c2c0719a47dd9c44f71ad6c62b56110b0eec09f118"
_WORDS = None


def _wordlist_path():
    """Resolve the English wordlist and whether to verify it against
    WORDLIST_SHA256. An explicit AI_DISTILL_WORDLIST override is operator trust
    — loaded as-is, unverified. The auto-resolved vendored copies are pinned
    (tamper-evident). A system dictionary is a degraded, unverified fallback."""
    env = os.environ.get("AI_DISTILL_WORDLIST")
    if env and os.path.isfile(env):
        return env, False
    here = os.path.dirname(os.path.realpath(__file__))
    for cand in (os.path.join(here, "ai-wordlist.txt.gz"),
                 os.path.join(HOME, ".local", "share", "ai", "wordlist.txt.gz")):
        if os.path.isfile(cand):
            return cand, True
    if os.path.isfile("/usr/share/dict/words"):
        return "/usr/share/dict/words", False
    return None, False


def _load_english():
    path, verify = _wordlist_path()
    if not path:
        sys.stderr.write("! no English wordlist found (looked for a vendored"
                         " ai-wordlist.txt.gz and /usr/share/dict/words); the"
                         " identifier screen will over-redact common words\n")
        return set()
    try:
        with open(path, "rb") as fh:
            raw = fh.read()
        if path.endswith(".gz"):
            if verify:
                got = hashlib.sha256(raw).hexdigest()
                if got != WORDLIST_SHA256:      # tamper on the pinned artifact
                    sys.stderr.write("✗ wordlist integrity check failed for %s\n"
                                     "  expected %s\n  got      %s\n"
                                     % (path, WORDLIST_SHA256, got))
                    sys.exit(1)
            text = gzip.decompress(raw).decode("utf-8", "replace")
        else:
            text = raw.decode("utf-8", "replace")
    except (OSError, gzip.BadGzipFile, UnicodeDecodeError) as exc:
        # A pinned artifact never reaches here (a bad hash exits above); this is
        # a corrupt/unreadable override or system dictionary — degrade to
        # over-redaction rather than abort the run.
        sys.stderr.write("! could not read wordlist %s (%s); the identifier"
                         " screen will over-redact common words\n" % (path, exc))
        return set()
    return {w.strip().lower() for w in text.splitlines() if w.strip()}


def _load_terms():
    """Technical known-terms (ai-terms.txt), a git-reviewed plaintext layer —
    trusted like the code that ships with it, so no separate hash pin. Comment
    (#) and blank lines are ignored. Absent file → no extra terms."""
    here = os.path.dirname(os.path.realpath(__file__))
    for path in (os.path.join(here, "ai-terms.txt"),
                 os.path.join(HOME, ".local", "share", "ai", "terms.txt")):
        if os.path.isfile(path):
            with open(path, encoding="utf-8") as fh:
                return {ln.strip().lower() for ln in fh
                        if ln.strip() and not ln.startswith("#")}
    return set()


def dictionary_words():
    """The released known-word set: the union of the English wordlist (SCOWL)
    and the technical known-terms (ai-terms.txt). Built once and cached; a token
    in it is a common word, not an operator identifier, and is not redacted."""
    global _WORDS
    if _WORDS is None:
        _WORDS = frozenset(_load_english() | _load_terms())
    return _WORDS


def is_identifier_token(tok):
    """A token worth redacting: longer than two characters and not a dictionary
    word — a common word is not the operator's identifier (§7 req 5.a)."""
    return len(tok) > 2 and tok.lower() not in dictionary_words()


def slug_tokens(slug):
    toks = set()
    if slug:
        toks.add(slug)
        for part in re.split(r"[-/_.\s]+", slug):
            if part and is_identifier_token(part):
                toks.add(part)
    return toks


def git_remote_identifiers(repo_dir):
    toks = set()
    try:
        url = subprocess.run(
            ["git", "-C", repo_dir, "remote", "get-url", "origin"],
            capture_output=True, text=True, timeout=5).stdout.strip()
    except (OSError, subprocess.SubprocessError):
        return toks
    if not url:
        return toks
    # host + owning-org path prefix + repo name (§7 req 5.a)
    m = re.match(r"(?:git@|ssh://git@|https://)?([^:/]+)[:/](.+?)(?:\.git)?$", url)
    if m:
        host, path = m.group(1), m.group(2)
        toks.add(host)
        for part in path.split("/"):
            if part:
                toks.add(part)
    return toks


def git_identity_tokens():
    """Operator identity from git config — name parts and the email local part —
    so a personal name is redacted before promotion without hardcoding it here
    (portable to any operator). Not dictionary-screened: build_denylist redacts
    these unconditionally, since a name that is also a common word is still the
    operator's name. Kept only in the local denylist, never committed."""
    toks = set()
    for key in ("user.name", "user.email"):
        try:
            val = subprocess.run(["git", "config", "--get", key],
                                 capture_output=True, text=True,
                                 timeout=5).stdout.strip()
        except (OSError, subprocess.SubprocessError):
            val = ""
        if not val:
            continue
        if "@" in val:
            val = val.split("@", 1)[0]
        for part in re.split(r"[-._\s]+", val):
            if len(part) > 2:
                toks.add(part)
    return toks


def build_denylist(slugs):
    # Path/repo/remote tokens: dictionary-screened, so an ordinary word among
    # them (e.g. "release", "main") is released rather than redacted.
    toks = set()
    for slug in slugs:
        toks |= slug_tokens(slug)
    if os.path.isdir(WORKSPACE_DIR):
        for name in sorted(os.listdir(WORKSPACE_DIR)):
            repo = os.path.join(WORKSPACE_DIR, name)
            if os.path.isdir(os.path.join(repo, ".git")):
                toks.add(name)
                toks |= git_remote_identifiers(repo)
    screened = {t for t in toks if is_identifier_token(t)}
    # The operator's own identity is redacted unconditionally — exempt from the
    # generic-word screen, since a name that is also a word is still their name.
    return sorted(screened | git_identity_tokens())


def scan_identifiers(text, denylist):
    low = text.lower()
    return sorted({t for t in denylist if re.search(
        r"\b%s\b" % re.escape(t.lower()), low)})


# ── Secret scan (§7 req 11) ────────────────────────────────────────────────

def gitleaks_available():
    try:
        subprocess.run(["gitleaks", "version"], capture_output=True, timeout=5)
        return True
    except (OSError, subprocess.SubprocessError):
        return False


def scan_secrets(text, use_gitleaks):
    hits = []
    if use_gitleaks:
        try:
            proc = subprocess.run(
                ["gitleaks", "stdin", "--no-banner", "--report-format", "json",
                 "--report-path", "/dev/stdout"],
                input=text, capture_output=True, text=True, timeout=30)
            if proc.stdout.strip():
                for f in json.loads(proc.stdout):
                    hits.append(f.get("RuleID", "gitleaks"))
                return sorted(set(hits))
        except (OSError, subprocess.SubprocessError, ValueError):
            pass  # fall through to builtin
    for name, pat in SECRET_PATTERNS:
        if pat.search(text):
            hits.append(name)
    return sorted(set(hits))


# ── git worktrees: a distilled change per target repo, off the live path ───
#
# Every repo a run touches (the workspace repo as the primary hub target, plus
# any suggest-to-repo target) gets a linked worktree on branch distill/<run>,
# branched from the live HEAD. The session edits the worktree directly; the
# live tree — what the tools read — is never touched until apply merges the
# reviewed branch in. On apply or discard the worktree and branch are removed,
# so no loose copies are left behind.

def git(repo, *args, check=True):
    proc = subprocess.run(["git", "-C", repo, *args],
                          capture_output=True, text=True)
    if check and proc.returncode != 0:
        sys.stderr.write("✗ git %s (in %s): %s\n"
                         % (" ".join(args), repo, proc.stderr.strip()))
        sys.exit(1)
    return proc


def is_git_repo(path):
    return os.path.isdir(path) and subprocess.run(
        ["git", "-C", path, "rev-parse", "--git-dir"],
        capture_output=True).returncode == 0


def load_targets(run_dir):
    return load_json(os.path.join(run_dir, "targets.json")) or {}


def save_targets(run_dir, targets):
    write_json(os.path.join(run_dir, "targets.json"), targets)


def add_worktree(run_dir, branch, repo, name, hub):
    """Create a distill/<run> worktree of `repo` under the run dir. Returns the
    target record; records the base commit for later diffing."""
    repo = os.path.realpath(repo)
    base = git(repo, "rev-parse", "HEAD").stdout.strip()
    wt = os.path.join(run_dir, "worktree-%s" % name)
    git(repo, "worktree", "add", "-b", branch, wt, "HEAD")
    return {"repo": repo, "worktree": wt, "branch": branch, "base": base,
            "hub": hub}


def has_commits(repo):
    return git(repo, "rev-parse", "--verify", "-q", "HEAD",
               check=False).returncode == 0


def remove_worktree(target):
    """Remove a worktree and its branch. Returns True on success; prunes stale
    admin state so nothing is left behind."""
    repo, wt, branch = target["repo"], target["worktree"], target["branch"]
    ok = git(repo, "worktree", "remove", "--force", wt, check=False).returncode == 0
    git(repo, "worktree", "prune", check=False)
    git(repo, "branch", "-D", branch, check=False)
    return ok and not os.path.exists(wt)


HUNK_HEADER = re.compile(r"^@@ -\d+(?:,(\d+))? \+\d+(?:,(\d+))? @@")


def worktree_change(target):
    """Structured change of a worktree vs its base, read from git's own machine
    output — never text-scraped — so deletions, renames, binary files, symlinks
    and mode changes are all seen. Returns (paths, added_lines, has_binary,
    nonregular):
      paths       — every path touched (adds, mods, deletes, both rename ends)
      added_lines — the exact content added, extracted by each hunk's declared
                    line counts (not by sniffing a line's leading character —
                    which a crafted '++'/header-shaped line could spoof), split
                    on '\\n' only (str.splitlines would also break on U+2028/
                    U+2029/NEL/VT/FF, orphaning part of a line out of the scan)
      has_binary  — any binary file among the changes
      nonregular  — [(path, mode)] for any new object that is not a regular file
                    (100644): symlink (120000), gitlink (160000), or the exec
                    bit (100755) — a filesystem-escape / non-prose vector (req 9)
    `add -N` (intent-to-add) makes untracked files show in the diff without
    staging their content, so the gate stays read-only-ish."""
    wt, base = target["worktree"], target["base"]
    git(wt, "add", "-N", "-A")
    paths = set()
    for line in git(wt, "diff", "--name-status", base).stdout.split("\n"):
        cols = line.split("\t")
        # A/M/D <path>, or R###/C### <old> <new> — take every named path.
        paths.update(c for c in cols[1:] if c)
    # Destination mode of every change, from --raw: `:<src> <dst> <sha> <sha>
    # <status>\t<path>[\t<path>]`. The meta half is space-separated and never
    # quoted (only the trailing path is), so partitioning on the first tab is
    # safe. Anything whose new mode is not a regular file (or a deletion) is a
    # non-prose vector — a symlink can point out of the repo, a gitlink pulls in
    # a submodule, the exec bit turns a "prose" file runnable.
    nonregular = []
    for line in git(wt, "diff", "--raw", base).stdout.split("\n"):
        if not line.startswith(":"):
            continue
        meta, _, rest = line.partition("\t")
        fields = meta[1:].split()
        if len(fields) < 2:
            continue
        dstmode = fields[1]
        if dstmode not in ("100644", "000000"):   # regular file / deleted
            nonregular.append((rest.split("\t")[-1] if rest else "", dstmode))
    has_binary = False
    for line in git(wt, "diff", "--numstat", base).stdout.split("\n"):
        cols = line.split("\t")
        if len(cols) >= 2 and cols[0] == "-" and cols[1] == "-":
            has_binary = True
    # Added content, driven by the hunk header's own counts. With --unified=0 a
    # hunk is exactly `removed` '-' lines then `added` '+' lines (plus optional
    # "\ No newline" markers). Consuming by count — not by matching '+'/'@@' on
    # a line, which attacker *content* could imitate once git prefixes it — is
    # immune to both the '++ '→'+++ ' header-spoof and any in-line separator.
    added = []
    lines = git(wt, "diff", "--unified=0", base).stdout.split("\n")
    i, n = 0, len(lines)
    while i < n:
        m = HUNK_HEADER.match(lines[i])
        if not m:
            i += 1
            continue
        removed = int(m.group(1)) if m.group(1) is not None else 1
        addn = int(m.group(2)) if m.group(2) is not None else 1
        i += 1
        seen = 0
        while i < n and seen < removed:              # skip removed lines
            if not lines[i].startswith("\\"):
                seen += 1
            i += 1
        took = 0
        while i < n and took < addn:                 # take added lines
            if lines[i].startswith("\\"):            # "\ No newline" marker
                i += 1
                continue
            added.append(lines[i][1:] if lines[i].startswith("+") else lines[i])
            i += 1
            took += 1
    return sorted(paths), "\n".join(added), has_binary, nonregular


def diff_fingerprint(target):
    """A stable hash of a target's whole change (modes + patch) vs its base, so
    apply can prove it is merging exactly the tree that gate approved and the
    operator reviewed — closing the review→apply TOCTOU (§7 req 12)."""
    wt, base = target["worktree"], target["base"]
    git(wt, "add", "-N", "-A")
    raw = git(wt, "diff", "--raw", base).stdout
    patch = git(wt, "diff", base).stdout
    return hashlib.sha256((raw + "\0" + patch).encode("utf-8")).hexdigest()


def check_target_diff(target, denylist, use_gitleaks):
    """Run the deterministic gates on a target's change. Returns (paths, errors)."""
    hub = target["hub"]
    paths, added, has_binary, nonregular = worktree_change(target)
    errors = []
    for f in paths:
        if hub:
            if not HUB_FILE.match(f):
                errors.append("changed a non-prose/out-of-ai path: %s" % f)
        elif EXEC_CONFIG.search(f):
            errors.append("changed an executable/config file: %s" % f)
    # Applies to every target: a symlink/gitlink/exec-bit file is never prose,
    # in the hub or a suggest-to-repo repo (req 9).
    for path, mode in nonregular:
        errors.append("not a regular file (mode %s) — symlinks, gitlinks and"
                      " the exec bit are refused (req 9): %s" % (mode, path))
    if hub and has_binary:
        errors.append("a binary file is among the changes — prose only (req 9)")
    if EXEC_CONTENT.search(added):
        errors.append("added content contains executable configuration"
                      " (MCP/command JSON) — prose only (req 9)")
    secrets = scan_secrets(added, use_gitleaks)
    if secrets:
        errors.append("secret(s) in added lines: %s" % ", ".join(secrets))
    if hub:
        ids = scan_identifiers(added, denylist)
        if ids:
            errors.append("unredacted identifier(s) in added lines: %s"
                          % ", ".join(ids[:5]))
    return paths, errors


# ── prepare (reqs 1–3) ─────────────────────────────────────────────────────

def prepare(run_dir=None):
    catalog = load_json(HARVEST_LATEST)
    if not isinstance(catalog, dict) or "resources" not in catalog:
        sys.stderr.write("✗ error: no usable harvest catalog at %s — run"
                         " ai-harvest first\n" % HARVEST_LATEST)
        sys.exit(1)

    derived = [r for r in catalog["resources"]
               if r.get("refinement") == "derived"]
    slugs_all = sorted({r.get("slug") for r in catalog.get("resources", [])
                        if r.get("slug")})

    items = {}   # canonical-hash -> item (exact-dup merge, req 7 cheap pass)
    excluded = []
    for res in sorted(derived, key=lambda r: r.get("url", "")):
        url = res.get("url", "")
        path = file_path_of(url)
        if path is None:
            excluded.append({"url": url, "reason": "non-file URL (not fetched, req 2)"})
            continue
        try:
            size = os.path.getsize(path)
        except OSError as exc:
            excluded.append({"url": url, "reason": "unreadable: %s" % exc})
            continue
        if size > MAX_FILE_BYTES:
            # Reject on size before reading/hashing — a pathologically large
            # file can't exhaust memory just to be excluded.
            excluded.append({"url": url, "reason": "invalid: oversize (%d bytes"
                             " > %d)" % (size, MAX_FILE_BYTES)})
            continue
        try:
            with open(path, "rb") as fh:
                data = fh.read()
        except OSError as exc:
            excluded.append({"url": url, "reason": "unreadable: %s" % exc})
            continue
        if sha256_bytes(data) != res.get("sha256"):
            excluded.append({"url": url, "reason": "sha256 mismatch — excluded (R2);"
                             " re-run ai-harvest"})
            continue
        san = sanitize(data)
        if "invalid" in san:
            excluded.append({"url": url, "reason": "invalid: %s" % san["invalid"]})
            continue
        key = sha256_bytes(san["text"].encode("utf-8"))
        if key in items:
            it = items[key]
            it["provenance"].append(url)
            if res.get("slug"):
                it["slugs"] = sorted(set(it["slugs"]) | {res["slug"]})
        else:
            items[key] = {
                "id": key[:12],
                "class": res.get("class"),
                "slugs": [res["slug"]] if res.get("slug") else [],
                "provenance": [url],
                "text": san["text"],
                "annotations": san["annotations"],
                "opacity_score": san["opacity_score"],
                "chars": len(san["text"]),
            }

    item_list = sorted(items.values(), key=lambda it: (-len(it["slugs"]), it["id"]))
    denylist = build_denylist(slugs_all)

    stamp = now().strftime("%Y%m%dT%H%M%SZ")
    run_dir = run_dir or os.path.join(STATE, "run-%s" % stamp)
    os.makedirs(run_dir, mode=0o700, exist_ok=True)
    os.chmod(run_dir, 0o700)

    write_json(os.path.join(run_dir, "items.json"), {
        "_note": "ai-distill work package — sanitized, exact-deduplicated"
                 " derived items for the distillation session (reqs 1–3).",
        "generated": iso(now().timestamp()),
        "catalog": os.path.realpath(HARVEST_LATEST),
        "items": item_list,
        "excluded": excluded,
    })
    write_json(os.path.join(run_dir, "denylist.json"), {
        "_note": "Identifier denylist for redaction/screening (req 5.a). Local"
                 " state; never committed.",
        "identifiers": denylist,
    })
    write_report(run_dir, item_list, excluded, denylist)

    latest = os.path.join(os.path.dirname(os.path.abspath(run_dir)), "latest")
    tmp = latest + ".tmp"
    try:
        os.remove(tmp)
    except FileNotFoundError:
        pass
    os.symlink(os.path.basename(os.path.abspath(run_dir)), tmp)
    os.replace(tmp, latest)

    # Quarantine pen — suspected injections the session sets aside; held here,
    # outside every repo, until the operator judges one a false alarm.
    os.makedirs(os.path.join(run_dir, "quarantine"), mode=0o700, exist_ok=True)

    # Primary worktree: the workspace repo's ai/ on branch distill/<run>.
    run_name = os.path.basename(os.path.abspath(run_dir))
    branch = "distill/%s" % run_name
    targets = {"run": run_name, "branch": branch, "targets": {}}
    no_worktree = None
    if not is_git_repo(WORKSPACE_DIR):
        no_worktree = "not a git repo"
    elif not has_commits(WORKSPACE_DIR):
        no_worktree = "has no commits yet"
    elif git(WORKSPACE_DIR, "rev-parse", "--verify", branch,
             check=False).returncode == 0:
        sys.stderr.write("✗ error: branch %s already exists in %s\n"
                         % (branch, WORKSPACE_DIR))
        sys.exit(1)
    if no_worktree is None:
        targets["targets"]["workspace"] = add_worktree(
            run_dir, branch, WORKSPACE_DIR, "workspace", hub=True)
    save_targets(run_dir, targets)

    flagged = sum(1 for it in item_list if it["opacity_score"] or it["annotations"])
    print("→ prepared %d item(s) (%d flagged), %d excluded → %s"
          % (len(item_list), flagged, len(excluded), run_dir))
    wt = targets["targets"].get("workspace", {}).get("worktree")
    if wt:
        print("→ edit the distilled ai/ in the worktree (branch %s):" % branch)
        print("     %s/ai" % wt)
        print("→ then: ai-distill gate %s   (checks the branch diff)" % run_dir)
        print("→ then, on approval: ai-distill apply %s" % run_dir)
    else:
        sys.stderr.write("! workspace %s %s — work package only; set"
                         " AI_WORKSPACE_DIR to a committed git repo to enable"
                         " the worktree flow\n" % (WORKSPACE_DIR, no_worktree))


def write_report(run_dir, items, excluded, denylist):
    """The run digest — a summary and minimalist lists, not a content dump.
    prepare writes the deterministic input side (attention flags, mechanical
    exclusions); the session appends the routing outcomes (quarantine first,
    promotions last) at the end of the run. The full item text lives in
    items.json and, once distilled, in the git diff, so it is not repeated
    here. This file is kept as a small forensic record after items.json is
    pruned on apply."""
    flagged = [it for it in items if it["opacity_score"] or it["annotations"]]
    lines = ["# Distillation run digest", "",
             "- candidate items: %d" % len(items),
             "- flagged for attention: %d" % len(flagged),
             "- excluded (mechanical): %d" % len(excluded),
             "- identifier denylist: %d" % len(denylist), ""]
    if flagged:
        lines += ["## Needs attention (opacity / lookalikes)", ""]
        for it in flagged:
            kinds = ",".join(sorted({a["kind"] for a in it["annotations"]}))
            lines.append("- `%s` opacity=%d [%s] slugs=%d"
                         % (it["id"], it["opacity_score"], kinds, len(it["slugs"])))
        lines.append("")
    if excluded:
        lines += ["## Excluded (mechanical)", ""]
        for e in excluded:
            lines.append("- %s — %s" % (e["reason"], e["url"]))
        lines.append("")
    lines += ["<!-- The session appends routing outcomes below:"
              " quarantined, suggest-to-repo, discarded, then promoted"
              " (minimal id → target). -->", ""]
    path = os.path.join(run_dir, "report.md")
    with open(path, "w", encoding="utf-8") as fh:
        fh.write("\n".join(lines) + "\n")
    os.chmod(path, 0o600)


# ── gate: run the deterministic checks on a target's branch diff ───────────

def _load_run(run_dir, require_targets=True):
    run_dir = os.path.realpath(run_dir or os.path.join(STATE, "latest"))
    targets = load_targets(run_dir)
    if "targets" not in targets:
        sys.stderr.write("✗ error: no run at %s — run ai-distill prepare"
                         " first\n" % run_dir)
        sys.exit(1)
    if require_targets and not targets["targets"]:
        sys.stderr.write("✗ error: run %s has no worktrees (the workspace was"
                         " not a git repo); add one with ai-distill"
                         " add-target\n" % run_dir)
        sys.exit(1)
    return run_dir, targets


def _denylist(run_dir):
    return (load_json(os.path.join(run_dir, "denylist.json"))
            or {}).get("identifiers", [])


def gate(run_dir, name=None):
    run_dir, targets = _load_run(run_dir)
    denylist = _denylist(run_dir)
    use_gitleaks = gitleaks_available()
    names = [name] if name else sorted(targets["targets"])
    all_ok = True
    dirty = False
    for nm in names:
        t = targets["targets"].get(nm)
        if not t:
            sys.stderr.write("✗ no target %r in this run\n" % nm)
            sys.exit(1)
        files, errors = check_target_diff(t, denylist, use_gitleaks)
        if errors:
            all_ok = False
            t.pop("gated", None)      # a failing gate revokes any earlier pass
            dirty = True
            sys.stderr.write("✗ %s: %d gate violation(s):\n" % (nm, len(errors)))
            for e in errors:
                sys.stderr.write("  ✗ %s\n" % e)
        else:
            # Pin exactly what was gated so apply can prove it merges the
            # reviewed tree and nothing was swapped in afterward (§7 req 12).
            t["gated"] = diff_fingerprint(t)
            dirty = True
            print("→ %s: gate clean — %d file(s) changed in %s"
                  % (nm, len(files), t["worktree"]))
    if dirty:
        save_targets(run_dir, targets)
    if not all_ok:
        sys.exit(1)
    print("→ review the diff, then: ai-distill apply %s" % run_dir)


# ── apply / discard: merge a reviewed branch into the live tree, or drop it ─

def _has_changes(target):
    return bool(worktree_change(target)[0])


def apply(run_dir, name=None):
    run_dir, targets = _load_run(run_dir)
    denylist = _denylist(run_dir)
    use_gitleaks = gitleaks_available()
    names = [name] if name else sorted(targets["targets"])
    for nm in names:
        t = targets["targets"].get(nm)
        if not t:
            sys.stderr.write("✗ no target %r in this run\n" % nm)
            sys.exit(1)
        if t.get("applied"):
            print("→ %s: already applied" % nm)
            continue
        if not _has_changes(t):
            print("→ %s: nothing to apply (worktree unchanged)" % nm)
            continue
        # Re-gate: never merge un-gated content.
        _, errors = check_target_diff(t, denylist, use_gitleaks)
        if errors:
            sys.stderr.write("✗ %s: refusing to apply — %d gate violation(s):\n"
                             % (nm, len(errors)))
            for e in errors:
                sys.stderr.write("  ✗ %s\n" % e)
            sys.exit(1)
        # Merge exactly the tree that was gated and reviewed — never whatever
        # the worktree drifted to after review (§7 req 12, review→apply TOCTOU).
        if t.get("gated") != diff_fingerprint(t):
            sys.stderr.write("✗ %s: the worktree changed since it was gated —"
                             " re-run 'ai-distill gate %s', review the refreshed"
                             " diff, then apply\n" % (nm, run_dir))
            sys.exit(1)
        repo, wt, branch, base = (t["repo"], t["worktree"], t["branch"],
                                  t["base"])
        # The live tree must be clean and idle: never disturb an operator's
        # uncommitted work or an in-progress merge/rebase.
        gitdir = git(repo, "rev-parse", "--git-dir").stdout.strip()
        gitdir = gitdir if os.path.isabs(gitdir) else os.path.join(repo, gitdir)
        if git(repo, "status", "--porcelain").stdout.strip() or \
                os.path.exists(os.path.join(gitdir, "MERGE_HEAD")):
            sys.stderr.write("✗ %s: workspace has uncommitted changes or an"
                             " in-progress merge — commit or clean it, then"
                             " re-run apply\n" % nm)
            sys.exit(1)
        # The branch must still sit on the current live tip; if the live ai/
        # moved since the run started, ask the operator to rebase rather than
        # risk a conflicting merge.
        live = git(repo, "symbolic-ref", "--short", "HEAD", check=False).stdout.strip()
        if git(repo, "rev-parse", "HEAD").stdout.strip() != base:
            sys.stderr.write("✗ %s: the live %s moved since this run started —"
                             " rebase %s onto it (or start a fresh run), then"
                             " apply\n" % (nm, live or "branch", branch))
            sys.exit(1)
        # Commit the reviewed worktree state, then SQUASH-merge so exactly the
        # gated net tree lands as one commit — no intermediate (un-gated)
        # commits enter the live history. Provenance from the branch's own
        # commit subjects is carried into the squash message.
        provenance = git(wt, "log", "--format=- %s", "%s..HEAD" % base,
                         check=False).stdout.strip()
        git(wt, "add", "-A")
        if git(wt, "status", "--porcelain").stdout.strip():
            git(wt, "commit", "-m", "distill: %s (worktree)" % targets["run"])
        msg = "distill: %s\n\n%s" % (targets["run"], provenance) if provenance \
            else "distill: %s" % targets["run"]
        squash = git(repo, "merge", "--squash", branch, check=False)
        if squash.returncode != 0:
            sys.stderr.write("✗ %s: squash-merge into %s failed:\n%s\n"
                             % (nm, live, (squash.stdout + squash.stderr).strip()))
            sys.exit(1)
        git(repo, "commit", "-m", msg)
        if not remove_worktree(t):
            sys.stderr.write("! %s: merged, but the worktree could not be"
                             " removed cleanly — remove it by hand: %s\n"
                             % (nm, wt))
        t["applied"] = True
        save_targets(run_dir, targets)
        print("→ %s: merged %s into %s; worktree removed" % (nm, branch, live))
    # Prune the one large, reconstructable intermediate (items.json) once every
    # target is resolved. Keep report.md, quarantine/, denylist.json,
    # targets.json — small state and forensic material — as the run record.
    if all(t.get("applied") or t.get("discarded")
           for t in targets["targets"].values()):
        big = os.path.join(run_dir, "items.json")
        if os.path.exists(big):
            os.remove(big)
            print("→ pruned items.json (large intermediate; rebuildable from"
                  " the catalog); kept report.md, quarantine/, and run state")
    print("→ done — the change is committed in the live repo history.")


def discard(run_dir, name=None):
    run_dir, targets = _load_run(run_dir)
    names = [name] if name else sorted(targets["targets"])
    for nm in names:
        t = targets["targets"].get(nm)
        if not t or t.get("applied"):
            continue
        remove_worktree(t)               # worktree and branch both removed
        t["discarded"] = True
        print("→ %s: worktree and branch removed (nothing applied)" % nm)
    save_targets(run_dir, targets)


# ── add-target: a worktree for a suggest-to-repo target (side channel) ─────

def add_target(run_dir, repo):
    if repo is None or not is_git_repo(repo) or not has_commits(repo):
        sys.stderr.write("✗ error: not a git repo with commits: %s\n" % repo)
        sys.exit(1)
    run_dir, targets = _load_run(run_dir, require_targets=False)
    branch = targets["branch"]
    name = os.path.basename(os.path.realpath(repo))
    if name in targets["targets"]:
        sys.stderr.write("✗ target %r already in this run\n" % name)
        sys.exit(1)
    if git(repo, "rev-parse", "--verify", branch, check=False).returncode == 0:
        sys.stderr.write("✗ branch %s already exists in %s\n" % (branch, repo))
        sys.exit(1)
    targets["targets"][name] = add_worktree(run_dir, branch, repo, name,
                                            hub=False)
    save_targets(run_dir, targets)
    wt = targets["targets"][name]["worktree"]
    print("→ added target %r — edit its instruction files in the worktree:"
          % name)
    print("     %s" % wt)
    print("→ then: ai-distill gate %s %s  →  apply %s %s   (or discard)"
          % (run_dir, name, run_dir, name))


USAGE = ("usage: ai-distill {prepare [run-dir] | gate [run-dir] [target]"
         " | apply [run-dir] [target] | discard [run-dir] [target]"
         " | add-target <run-dir> <repo>}\n")


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        sys.stderr.write(USAGE)
        sys.exit(0 if len(sys.argv) >= 2 else 2)
    cmd = sys.argv[1]
    a2 = sys.argv[2] if len(sys.argv) > 2 else None
    a3 = sys.argv[3] if len(sys.argv) > 3 else None
    if cmd == "prepare":
        prepare(a2)
    elif cmd == "gate":
        gate(a2, a3)
    elif cmd == "apply":
        apply(a2, a3)
    elif cmd == "discard":
        discard(a2, a3)
    elif cmd == "add-target":
        add_target(a2, a3)
    else:
        sys.stderr.write(USAGE)
        sys.exit(2)


if __name__ == "__main__":
    main()
