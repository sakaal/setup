#!/usr/bin/env python3
#
# ai-sync — render shared, agent-neutral sources into each present tool's own
# format, driven entirely by ~/.config/ai/agent-map.json. Deployed by setup; do
# not edit — edit setup's source (files/ai-sync) instead.
#
# This is the content-transform half of the sync architecture (the "generate"
# and "wrap" methods). Symlinks and @import stubs (the "link"/"import" methods)
# are laid by the setup playbook, not here. Both halves read the same manifest
# and loop it generically — no tool is hardcoded; adding one is a manifest edit.
#
# For each user-scope entry whose method needs a content transform, this looks
# up an emitter by the entry's "format" and applies it. Emitters are add-only
# and non-destructive: they add what is missing, leave anything already present
# (reporting a divergent same-named item as a conflict), and never delete.
# Uses only the standard library (works on the system python3, 3.9+).

import json
import os
import re
import sys

for _stream in (sys.stdout, sys.stderr):
    try:
        _stream.reconfigure(encoding="utf-8")
    except (AttributeError, ValueError):
        pass

HOME = os.path.expanduser("~")
CONFIG = os.path.join(HOME, ".config", "ai")
MANIFEST = os.path.join(CONFIG, "agent-map.json")

changed = []
conflicts = []
insync = []


def expand(path):
    return os.path.expanduser(path)


def load_json_file(path):
    try:
        with open(path, encoding="utf-8") as fh:
            text = fh.read()
        return json.loads(text) if text.strip() else {}
    except FileNotFoundError:
        return None
    except (ValueError, OSError) as exc:
        sys.stderr.write("✗ error: cannot read %s: %s\n" % (path, exc))
        return None


def mcp_servers_from(source_path):
    data = load_json_file(source_path)
    if not isinstance(data, dict):
        return {}
    servers = data.get("mcpServers")
    return servers if isinstance(servers, dict) else {}


def write_atomic(path, text):
    tmp = path + ".ai-sync.tmp"
    with open(tmp, "w", encoding="utf-8") as fh:
        fh.write(text)
    os.replace(tmp, path)


def toml_key(name):
    # Bare TOML keys allow only A-Za-z0-9_-; anything else must be quoted.
    if re.fullmatch(r"[A-Za-z0-9_-]+", name):
        return name
    return json.dumps(name)


# ── Emitters: (entry, source_path) -> mutate entry's target file ──────────

def emit_mcp_json(entry, source_path):
    servers = mcp_servers_from(source_path)
    if not servers:
        return
    path = expand(entry["path"])
    key = entry.get("key", "mcpServers")
    if os.path.exists(path):
        data = load_json_file(path)
        if data is None:
            return
    elif entry.get("create", True):
        data = {}
    else:
        return
    if not isinstance(data, dict):
        sys.stderr.write("! skip %s: top level is not an object\n" % path)
        return
    existing = data.get(key)
    if not isinstance(existing, dict):
        existing = {}
    added = 0
    for name, spec in servers.items():
        if name in existing:
            (insync if existing[name] == spec
             else conflicts).append("%s: %s%s" % (path, name,
                                     "" if existing[name] == spec else " differs (left as-is)"))
            continue
        existing[name] = spec
        added += 1
    if added:
        data[key] = existing
        write_atomic(path, json.dumps(data, indent=2) + "\n")
        changed.append("%s (+%d server(s))" % (path, added))


def render_toml_table(name, spec):
    lines = ["[mcp_servers.%s]" % toml_key(name)]
    if "command" in spec:
        lines.append("command = %s" % json.dumps(spec["command"]))
    if isinstance(spec.get("args"), list):
        lines.append("args = %s" % json.dumps(spec["args"]))
    env = spec.get("env")
    if isinstance(env, dict) and env:
        lines.append("[mcp_servers.%s.env]" % toml_key(name))
        for env_key in env:
            lines.append("%s = %s" % (toml_key(env_key), json.dumps(env[env_key])))
    return "\n".join(lines)


def emit_mcp_toml(entry, source_path):
    # No TOML parser in the stdlib before 3.11, so operate on text: a server is
    # present iff its table header exists. Add-only; never edits an existing one.
    servers = mcp_servers_from(source_path)
    if not servers:
        return
    path = expand(entry["path"])
    try:
        with open(path, encoding="utf-8") as fh:
            text = fh.read()
    except FileNotFoundError:
        text = ""
    except OSError as exc:
        sys.stderr.write("! skip %s: %s\n" % (path, exc))
        return
    additions = []
    for name, spec in servers.items():
        header = re.compile(r"(?m)^\s*\[mcp_servers\.(?:%s|%s)\]"
                            % (re.escape(name), re.escape(json.dumps(name))))
        if header.search(text):
            insync.append("%s: %s" % (path, name))
        else:
            additions.append(render_toml_table(name, spec))
    if additions:
        if text and not text.endswith("\n"):
            text += "\n"
        write_atomic(path, text + "\n" + "\n\n".join(additions) + "\n")
        changed.append("%s (+%d server(s))" % (path, len(additions)))


EMITTERS = {
    "mcp-json": emit_mcp_json,
    "mcp-toml": emit_mcp_toml,
}


def main():
    manifest = load_json_file(MANIFEST)
    if not isinstance(manifest, dict):
        sys.stderr.write("✗ error: no usable manifest at %s\n" % MANIFEST)
        sys.exit(1)
    detect = manifest.get("detect", {})

    def present(tool):
        d = detect.get(tool)
        return bool(d) and os.path.isdir(expand(d))

    acted = False
    for entry in manifest.get("entries", []):
        if entry.get("scope") != "user":
            continue
        if entry.get("sync") not in ("generate", "wrap"):
            continue
        if not entry.get("path") or not present(entry["tool"]):
            continue
        acted = True
        emitter = EMITTERS.get(entry.get("format"))
        if emitter is None:
            sys.stderr.write("! skip %s: no emitter for format '%s'\n"
                             % (entry["path"], entry.get("format")))
            continue
        source = os.path.join(CONFIG, entry["source"])
        emitter(entry, source)

    for item in changed:
        print("→ changed: %s" % item)
    for item in conflicts:
        print("! conflict: %s" % item)
    if not changed and not conflicts:
        print("→ nothing to sync" if not acted else "→ all present tools already in sync")


if __name__ == "__main__":
    main()
