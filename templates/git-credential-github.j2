#!/bin/sh
#
# git-credential-github — git credential helper that fetches the
# GitHub Personal Access Token from Proton Pass on demand. Configured
# via:
#
#   git config --global credential.https://github.com.helper "$HOME/bin/git-credential-github"
#
# git invokes the helper with `get`/`store`/`erase` as the first arg.
# We only respond to `get`; the others are no-ops since we don't
# manage local cache state — Pass is the source of truth.
#
# Deployed by setup; do not edit. Edit setup's template instead.

case "$1" in
  get)
    printf 'username=%s\npassword=%s\n' \
      "$(pass-cli item view 'pass://Setup Keys/github-pat/username')" \
      "$(pass-cli item view 'pass://Setup Keys/github-pat/password')"
    ;;
esac
