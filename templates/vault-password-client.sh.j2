#!/bin/sh
#
# vault-password-client.sh — fetch an Ansible Vault password from Proton Pass
# on demand. Ansible invokes this with --vault-id <id> and reads the
# password from stdout. Items in Pass are stored at:
#
#   pass://Setup Keys/vault_pass-<vault-id>/password
#
# Deployed by setup; do not edit. Edit setup's template instead.

case "$1" in
  --vault-id) exec pass-cli item view "pass://Setup Keys/vault_pass-$2/password" ;;
esac
exit 1
